# Telegram
BOT_TOKEN=123456:replace-me

# core-service
CORE_HTTP_ADDR=:8080
CORE_GRPC_ADDR=:9090
CORE_DB_DSN=postgres://buddygym:buddygym@localhost:5432/core_db?sslmode=disable
REDIS_ADDR=localhost:6379
# min 32 bytes, generate: openssl rand -hex 32
JWT_SECRET=replace-me-with-32-plus-random-bytes
JWT_TTL=24h

# checkin-service (Python)
CHECKIN_GRPC_ADDR=localhost:9091
CHECKIN_DB_DSN=postgres://buddygym:buddygym@localhost:5432/checkin_db?sslmode=disable

# object storage
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=buddygym
S3_SECRET_KEY=buddygym-secret
S3_BUCKET=checkin-photos
GEOAPIFY_API_KEY=

# postgres container
POSTGRES_USER=buddygym
POSTGRES_PASSWORD=buddygym

# minio container
MINIO_ROOT_USER=buddygym
MINIO_ROOT_PASSWORD=buddygym-secret

# notification bot (bot-service). dry-run renders cards to disk and sends nothing
BOT_MODE=dry-run
BOT_NOTIFY_TOKEN=
